---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WritingStack from '../components/sections/WritingStack.astro';
import { siteConfig } from '../site.config';

const allPosts = await getCollection('writing');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const posts = allPosts.map((entry) => ({
  title: entry.data.title,
  date: entry.data.date,
  annotation: entry.data.annotation,
  type: entry.data.type,
  url:
    entry.data.type === 'curated'
      ? (entry.data.externalUrl ?? '#')
      : `/writing/${entry.slug}/`,
}));
---

<BaseLayout
  title="Writing"
  description={`Essays and curated reading by ${siteConfig.authorFullName}.`}
  canonicalUrl={Astro.url.href}
>
  <WritingStack
    posts={posts}
decorLeft={`${siteConfig.assetBaseUrl}/images/icq-logo-sticker.png`}
    decorRight={`${siteConfig.assetBaseUrl}/images/sympatico-disc.png`}
  />
</BaseLayout>
