---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import IntroBlock from '../components/sections/IntroBlock.astro';
import PillarCards from '../components/sections/PillarCards.astro';
import LatestWriting from '../components/sections/LatestWriting.astro';
import WorkBlock from '../components/sections/WorkBlock.astro';
import { siteConfig } from '../site.config';

const allPosts = await getCollection('writing');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestPosts = allPosts.slice(0, 3).map((entry) => ({
  title: entry.data.title,
  date: entry.data.date,
  annotation: entry.data.annotation,
  type: entry.data.type,
  url: entry.data.type === 'curated'
    ? (entry.data.externalUrl ?? '#')
    : `/writing/${entry.slug}/`,
}));

const pillars = [
  {
    title: 'Keep Your Promises',
    body: "Businesses run on promises. You make a promise to deliver a product, a service, or a career. Good businesses keep their promises. I help them do that.",
  },
  {
    title: 'Tech as an Enabler, not an End',
    body: "While technology changes fast, your basic business promises probably don't. Technology can be a tool to help you deliver, and I help decipher what's worth chasing, and what's just a trend.",
  },
  {
    title: 'People First',
    body: "We build businesses to support ourselves and our families and uplift our communities. Profits make this possible, but when profits start hurting people, it misses the point.",
  },
];

---

<BaseLayout
  title={siteConfig.authorFullName}
  overrideTitle={`${siteConfig.authorFullName} — President, ${siteConfig.employerName}`}
  description="I've been on the internet since MUDs and Geocities, and I'm still trying to figure out what we built. President of Cantilever, a digital agency."
  canonicalUrl={Astro.url.href}
  navTheme="dark"
  navOverHero={true}
>

  <IntroBlock
    title={siteConfig.authorFullName}
    body="When I was a kid, the Internet was going to change everything. It has - just not in the ways we were hoping. Twenty years in, I'm reckoning with the decisions we made, and the culture we built. Can we still deliver on the promise? Welcome to my website. Don't forget to sign the guestbook."
    photo={`${siteConfig.assetBaseUrl}/images/andrew-kid-computer.jpg`}
    photoAlt="Andrew as a kid with a computer"
  />

  <LatestWriting
    posts={latestPosts}
    blurb="In a world where opinions are inescapable noise, I try to limit by writing to things worth reading."
  />

  <WorkBlock
    body={`I'm President of ${siteConfig.employerName}, a digital agency  I've been part of since 2012. We build and maintain websites for organizations that take their digital presence seriously — strategy, design, and development, from a team that's been doing this long enough to know how to get you real results.`}
    ctaPrefix="If you're thinking about your website, "
    ctaLinkText="we'd like to talk"
    ctaUrl={`${siteConfig.employerUrl}?utm_source=andrewheins.ca&utm_medium=personal_site&utm_campaign=work_section`}
    stickerUrl={`${siteConfig.assetBaseUrl}/images/cantilever-sticker.png`}
    splotchUrl={`${siteConfig.assetBaseUrl}/images/splotch-light-cropped.png`}
  />

  <PillarCards
    title="How I Think"
    pillars={pillars}
  />

</BaseLayout>
