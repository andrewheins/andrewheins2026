---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoEntrance from '../components/sections/VideoEntrance.astro';
import IntroBlock from '../components/sections/IntroBlock.astro';
import PillarCards from '../components/sections/PillarCards.astro';
import WorkBlock from '../components/sections/WorkBlock.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import { siteConfig } from '../site.config';

const pillars = [
  {
    title: 'Keep Your Promises',
    body: "Businesses run on promises. You make a promise to deliver a product, a service, or a career. Good businesses keep their promises. I help them do that.",
  },
  {
    title: 'Tech as an Enabler, not an End',
    body: "While technology changes fast, your basic business promises probably don't. Technology can be a tool to help you deliver, and I help decipher what worth chasing, and what's just a trend.",
  },
  {
    title: 'People First',
    body: "We build businesses to support ourselves and our families and uplift our communities. Profits make this possible, but when profits start hurting people, it misses the point.",
  },
];

---

<BaseLayout
  title={siteConfig.authorFullName}
  description={`${siteConfig.authorFullName} is President of ${siteConfig.employerName}.`}
  canonicalUrl={Astro.url.href}
  navTheme="dark"
>

  <VideoEntrance
    video_desktop="https://assets.andrewheins.ca/video/rain-desktop.mp4"
    video_mobile="https://assets.andrewheins.ca/video/rain-mobile.mp4"
    title={`${siteConfig.authorFullName}`}
    subtitle={`President at ${siteConfig.employerName}, a digital agency. I've been on the internet since MUDs and Geocities, and I'm still trying to figure out what we built. I still think we can deliver on the promise we saw in it as kids.`}
  />

  <IntroBlock body="When I was a kid, the Internet was going to change everything. It has - just not in the ways we were hoping. Twenty years in, I'm reckoning with the decisions we made, and the culture we built. Can we still deliver on the promise? Welcome to my website. Don't forget to sign the guestbook." />

  <PillarCards
    title="How I Think"
    intro="A few principles have shaped how I think about this work. They're not a framework I invented — they're patterns I kept running into until I started taking them seriously."
    pillars={pillars}
  />

  <WorkBlock
    body={`I'm President of ${siteConfig.employerName}, a digital agency  I've been part of since 2012. We build and maintain websites for organizations that take their digital presence seriously — strategy, design, and development, from a team that's been doing this long enough to know how to get you real results.`}
    ctaPrefix="If you're thinking about your website, "
    ctaLinkText="we'd like to talk"
    ctaUrl={`${siteConfig.employerUrl}?utm_source=andrewheins.ca&utm_medium=personal_site&utm_campaign=work_section`}
    stickerUrl={`${siteConfig.assetBaseUrl}/images/cantilever-sticker.png`}
  />

  <ContactSection
    heading="Get in touch"
    intro={`I'm reachable by email and on LinkedIn. If you have a question about digital strategy, want to discuss something I've written, or are interested in working with ${siteConfig.employerName}, I'd like to hear from it.`}
    email={siteConfig.contactEmail}
    linkedInUrl={siteConfig.linkedInUrl}
  >
    <ContactForm workerEndpoint={siteConfig.workerEndpoint} />
  </ContactSection>
</BaseLayout>
