---
import BaseLayout from './BaseLayout.astro';
import VideoEntrance from '../components/sections/VideoEntrance.astro';
import AuthorBlock from '../components/sections/AuthorBlock.astro';
import { siteConfig } from '../site.config';

interface Props {
  title: string;
  description: string;
  annotation?: string;
  date: Date;
  video_desktop?: string;
  video_mobile?: string;
  poster_desktop?: string;
  poster_mobile?: string;
  focus_desktop?: string;
  focus_mobile?: string;
  title_appears_at?: number;
  freeze_at?: number;
}

const {
  title,
  description,
  annotation,
  date,
  video_desktop,
  video_mobile,
  poster_desktop,
  poster_mobile,
  focus_desktop,
  focus_mobile,
  title_appears_at,
  freeze_at,
} = Astro.props;

const hasVideo = !!(video_desktop || video_mobile);
const hasEntrance = hasVideo || !!(poster_desktop || poster_mobile);
// Note: the 100vh scroll offset is now emitted by VideoEntrance itself as a sibling spacer div.
const canonicalUrl = Astro.url.href;
const ogImage = poster_desktop || siteConfig.ogImageDefault;

---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  isArticle={true}
>

  {hasEntrance && (
    <VideoEntrance
      video_desktop={video_desktop}
      video_mobile={video_mobile}
      poster_desktop={poster_desktop}
      focus_desktop={focus_desktop}
      focus_mobile={focus_mobile}
      title_appears_at={title_appears_at}
      freeze_at={freeze_at}
      title={title}
      subtitle={annotation ?? siteConfig.authorFullName}
    />
  )}

  <div class="article-outer">
    <article class="py-16 prose prose-gray max-w-none article-prose">
      <slot />
    </article>

    <div class="max-w-3xl mx-auto px-4">
      <AuthorBlock
        name={siteConfig.authorFullName}
        headshotUrl={siteConfig.headshotUrl}
        bio={siteConfig.authorBio}
        employerName={siteConfig.employerName}
        employerUrl={siteConfig.employerUrl}
      />
    </div>
  </div>

  <!-- Panel backdrop -->
  <div id="panel-backdrop" aria-hidden="true"></div>

  <style>
    /* h2/h3/h4 font is set globally in BaseLayout — no override needed here */

    :global(.article-prose > p:first-of-type) {
      font-size: 1.25rem;
      line-height: 1.75;
      color: #111827;
    }

    .article-outer {
      max-width: 56rem; /* wider than 3xl to give room for floating images */
      margin-left: auto;
      margin-right: auto;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    /* Constrain prose text to readable width; float children can escape */
    .article-prose {
      max-width: 48rem;
      margin-left: auto;
      margin-right: auto;
    }

    /* Slide main content left when a panel is open — :global because main lives in BaseLayout */
    :global(main) {
      transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    }

    :global(main.panel-active) {
      /* -50% matches the 50vw panel — article and panel each own half the screen */
      transform: translateX(-50%);
    }

    @media (max-width: 640px) {
      :global(main.panel-active) {
        /* Panel is 100vw on mobile — shift article fully off-screen */
        transform: translateX(-100%);
      }
    }

    #panel-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 40;
      cursor: pointer;
    }

    #panel-backdrop.is-visible {
      display: block;
    }
  </style>

  <script>
    const main = document.querySelector('main');
    const backdrop = document.getElementById('panel-backdrop');

    // position: fixed elements inside a transformed ancestor are contained by
    // that ancestor, not the viewport. When main gets translateX(-40%) the panels
    // would anchor to main instead of the screen edge. Portal them to body first.
    document.querySelectorAll('.b-line-panel').forEach(p => document.body.appendChild(p));
    if (backdrop) document.body.appendChild(backdrop);

    function openPanel(panelId: string) {
      const panel = document.getElementById(`panel-${panelId}`);
      if (!panel) return;
      // Reset all panels
      document.querySelectorAll('.b-line-panel').forEach((p) => {
        p.removeAttribute('hidden');
        (p as HTMLElement).classList.remove('is-open');
      });
      panel.removeAttribute('hidden');
      requestAnimationFrame(() => {
        panel.classList.add('is-open');
      });
      main?.classList.add('panel-active');
      backdrop?.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
    }

    function closeAllPanels() {
      document.querySelectorAll('.b-line-panel.is-open').forEach((p) => {
        p.classList.remove('is-open');
        p.addEventListener('transitionend', () => p.setAttribute('hidden', ''), { once: true });
      });
      main?.classList.remove('panel-active');
      backdrop?.classList.remove('is-visible');
      document.body.style.overflow = '';
    }

    document.addEventListener('bline:open-panel', (e: Event) => {
      const { panelId } = (e as CustomEvent).detail;
      openPanel(panelId);
    });

    backdrop?.addEventListener('click', closeAllPanels);

    document.querySelectorAll('[data-panel-close]').forEach((btn) => {
      btn.addEventListener('click', closeAllPanels);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAllPanels();
    });
  </script>

  <!-- Scroll depth tracking for articles -->
  <script>
    const article = document.querySelector('article');
    if (article) {
      const thresholds = [0.25, 0.5, 0.75, 1.0];
      const fired = new Set<number>();

      window.addEventListener('scroll', function () {
        const scrollY = window.scrollY;
        const articleRect = article.getBoundingClientRect();
        const articleTop = scrollY + articleRect.top;
        const articleHeight = article.offsetHeight;
        const progress = (scrollY + window.innerHeight - articleTop) / articleHeight;

        thresholds.forEach(function (t) {
          if (progress >= t && !fired.has(t)) {
            fired.add(t);
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: 'article_scroll_depth',
              depth: Math.round(t * 100),
            });
          }
        });
      }, { passive: true });
    }
  </script>
</BaseLayout>
