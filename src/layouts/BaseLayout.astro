---
import { siteConfig } from '../site.config';
import Nav from '../components/sections/Nav.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteConfig.authorFullName,
  url: siteConfig.siteBaseUrl,
  image: siteConfig.headshotUrl,
  jobTitle: 'President',
  worksFor: {
    '@type': 'Organization',
    name: siteConfig.employerName,
    url: siteConfig.employerUrl,
  },
  sameAs: [siteConfig.linkedInUrl, siteConfig.workBlogAuthorProfileUrl],
};

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  isArticle?: boolean;
  navTheme?: 'light' | 'dark';
  navOverHero?: boolean;
}

const {
  title,
  description,
  ogImage = siteConfig.ogImageDefault,
  canonicalUrl = Astro.url.href,
  isArticle = false,
  navTheme = 'light',
  navOverHero = false,
} = Astro.props;

const pageTitle = `${title} — ${siteConfig.authorFullName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />

    <!-- Open Graph -->
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.authorFullName} — Writing`} href="/rss.xml" />

    <!-- CookieYes — async so it doesn't block rendering; consent defaults below
         are set synchronously before this script executes, preserving PIPEDA compliance -->
    <script
      id="cookieyes"
      type="text/javascript"
      async
      src={`https://cdn-cookieyes.com/client_data/${siteConfig.cookieYesScriptId}/script.js`}
    ></script>

    <!-- Consent defaults must run synchronously before any analytics load.
         All consent defaults to denied — zero data collected before explicit
         user consent, satisfying PIPEDA requirements for Canadian audiences. -->
    <script define:vars={{ ga4MeasurementId: siteConfig.ga4MeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }

      // Default everything denied — must run before gtag.js loads
      gtag('consent', 'default', {
        analytics_storage:              'denied',
        ad_storage:                     'denied',
        ad_user_data:                   'denied',
        ad_personalization:             'denied',
        functionality_storage:          'denied',
        personalization_storage:        'denied',
        security_storage:               'granted', // always allowed (CSRF etc.)
        wait_for_update:                500,
      });

      document.addEventListener('cookieyes-consent-update', function (event) {
        const detail = event.detail || {};

        if (detail.analytics === 'yes') {
          // Upgrade consent before the script loads so GA4 captures this page view
          gtag('consent', 'update', {
            analytics_storage:       'granted',
            functionality_storage:   'granted',
            personalization_storage: 'granted',
          });

          // Dynamically inject gtag.js — only fires once per session
          if (!document.getElementById('ga4-script')) {
            const s = document.createElement('script');
            s.id    = 'ga4-script';
            s.async = true;
            s.src   = `https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`;
            document.head.appendChild(s);

            // Configure GA4: disable ad signals, respect consent mode
            gtag('js', new Date());
            gtag('config', ga4MeasurementId, {
              allow_google_signals:              false, // no remarketing / audience
              allow_ad_personalization_signals:  false,
              restricted_data_processing:        true,  // CCPA / PIPEDA safe mode
            });
          }
        }
      });
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Async font loading — eliminates render-blocking; noscript fallback for non-JS environments -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Rock+Salt&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Rock+Salt&display=swap" />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <slot name="head" />
  </head>
  <style>
    html { font-size: 18px; }
    :global(h2, h3, h4) { font-family: 'Rock Salt', cursive; }
    :global(body) { min-height: 100dvh; display: flex; flex-direction: column; }
    :global(body > *:not(footer)) { flex-shrink: 0; }
    :global(body > footer) { margin-top: auto; }
  </style>
  <body class="text-gray-900 font-sans antialiased overflow-x-hidden" style="background-color: #f8f5f0; background-image: radial-gradient(ellipse at 50% -5%, #e4ddd2 0%, #f8f5f0 60%);">


{navOverHero ? (
      <div class="relative">
        <div class="absolute top-0 left-0 right-0 z-60 pointer-events-none">
          <div class="pointer-events-auto">
            <Nav theme={navTheme} />
          </div>
        </div>
        <main>
          <slot />
        </main>
      </div>
    ) : (
      <>
        <Nav theme={navTheme} />
        <main>
          <slot />
        </main>
      </>
    )}

    <footer class="border-t border-gray-100">
      <div class="max-w-3xl mx-auto px-4 py-8 text-sm text-gray-600 flex items-center justify-between">
        <span>&copy; {new Date().getFullYear()} {siteConfig.authorFullName}</span>
        <a
          href={siteConfig.linkedInUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-gray-900 transition-colors"
        >LinkedIn</a>
      </div>
    </footer>

    <!-- External link tracking — fires GA4 events for all outbound clicks.
         cantilever_referral and newsletter_signup are marked as key events
         in GA4 Admin → Events → Mark as key event. -->
    <script define:vars={{ workBlogUrl: siteConfig.workBlogUrl, cantileverUrl: siteConfig.employerUrl }}>
      document.addEventListener('click', function (e) {
        const a = e.target.closest('a');
        if (!a) return;
        const href = a.getAttribute('href') || '';
        if (!href.startsWith('http') || href.startsWith(window.location.origin)) return;

        if (typeof gtag === 'undefined') return;

        const isCantilever = href.startsWith(cantileverUrl);
        const isWorkBlog   = href.startsWith(workBlogUrl);

        if (isCantilever) {
          gtag('event', 'cantilever_referral', { link_url: href });
        } else if (isWorkBlog) {
          gtag('event', 'work_blog_click', { link_url: href });
        } else {
          gtag('event', 'external_link_click', { link_url: href });
        }
      });
    </script>
  </body>
</html>
