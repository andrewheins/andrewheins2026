---
// Author interjection — watercolor splotch background, text centered on top
---
<aside class="b-line-aside not-prose">
  <img
    src="https://assets.andrewheins.ca/images/splotch-light-cropped.png"
    alt=""
    aria-hidden="true"
    class="b-line-aside-bg"
  />
  <div class="b-line-aside-inner">
    <slot />
  </div>
</aside>

<style>
  .b-line-aside {
    position: relative;
    margin: 2.5rem 0;
  }

  /* Desktop default: image in normal flow sets the container height */
  .b-line-aside-bg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Text floats on top of the image */
  .b-line-aside-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 3rem;
    font-family: 'Rock Salt', cursive;
    font-size: 1.25rem;
    line-height: 2.0;
    color: #374151;
    text-align: center;
  }

  .b-line-aside-inner :global(p) {
    margin: 0;
  }

  .b-line-aside-inner :global(p + p) {
    margin-top: 0.75rem;
  }

  /* Mobile: text drives the container height; image contained behind it */
  @media (max-width: 639px) {
    .b-line-aside {
      overflow: hidden;
    }

    .b-line-aside-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
    }

    .b-line-aside-inner {
      position: relative;
      z-index: 1;
      padding: 2rem 1.5rem;
      font-size: 1rem;
    }
  }
</style>
