---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div
  class="b-line-panel"
  id={`panel-${id}`}
  role="dialog"
  aria-modal="true"
  aria-label={title}
  hidden
>
  <header class="b-line-panel-header">
    <button
      class="b-line-panel-back"
      type="button"
      aria-label="Close panel and return to article"
      data-panel-close
    >
      <!-- Tape strip wraps only the label so it sizes to content, not full width -->
      <span class="b-line-panel-back-tape">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back to article
      </span>
    </button>
    <div class="b-line-panel-title-bar">
      <span class="b-line-panel-title">{title}</span>
    </div>
  </header>

  <div class="b-line-panel-body">
    <slot />
  </div>
</div>

<style>
  /* ── Panel ────────────────────────────────────────────────────────────── */
  .b-line-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: min(56rem, 92vw);
    height: 100dvh;
    background: url('https://assets.andrewheins.ca/images/graph-paper.png') left top / cover no-repeat;
    z-index: 50;
    transform-origin: top right;
    transform: translateX(130%) rotate(8deg);
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .b-line-panel:not([hidden]) {
    display: flex !important;
  }

  .b-line-panel.is-open {
    transform: translateX(0) rotate(0deg);
  }

  /* ── Header ───────────────────────────────────────────────────────────── */
  .b-line-panel-header {
    flex-shrink: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  /* Full-width click target; the tape visual lives on the inner span */
  .b-line-panel-back {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.875rem 2rem 0.875rem 9.375rem; /* 150px left clears binding */
    background: transparent;
    border: none;
    cursor: pointer;
  }

  /* Scotch-tape strip — mirrors the Nav tape treatment */
  .b-line-panel-back-tape {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    position: relative;
    padding: 0.3rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #2a1f0e;
    transform: rotate(-0.7deg);
  }

  .b-line-panel-back-tape::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.75) 0%,
      rgba(255, 255, 255, 0.92) 25%,
      rgba(255, 255, 255, 0.92) 75%,
      rgba(255, 255, 255, 0.75) 100%
    );
    border-left:  1px solid rgba(200, 200, 200, 0.6);
    border-right: 1px solid rgba(200, 200, 200, 0.6);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.12), 0 1px 2px rgba(0, 0, 0, 0.08);
    filter: url(#tape-fray);
  }

  .b-line-panel-back:hover .b-line-panel-back-tape {
    opacity: 0.8;
  }

  .b-line-panel-title-bar {
    padding: 0.5rem 2rem 1rem 9.375rem; /* 150px left */
  }

  /* Rock Salt h2-style title */
  .b-line-panel-title {
    font-family: 'Rock Salt', cursive;
    font-size: 1rem;
    font-weight: 400;
    color: #2a1f0e;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  /* ── Body ─────────────────────────────────────────────────────────────── */
  .b-line-panel-body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    /* 100px top, 150px left — clears the torn binding edge */
    padding: 6.25rem 2rem 2rem 9.375rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #374151;
  }

  .b-line-panel-body :global(img),
  .b-line-panel-body :global(svg) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  .b-line-panel-body :global(p) {
    margin-bottom: 1rem;
  }

  .b-line-panel-body :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .b-line-panel {
      /* Full bleed — a sliver of article still peeks past the binding holes */
      width: 100vw;
    }

    .b-line-panel-back {
      padding-left: 7rem;
    }

    .b-line-panel-title-bar {
      padding-left: 7rem;
    }

    .b-line-panel-body {
      padding: 3.5rem 1.25rem 2rem 7rem;
    }
  }
</style>
