---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div
  class="b-line-panel"
  id={`panel-${id}`}
  role="dialog"
  aria-modal="true"
  aria-label={title}
  hidden
>
  <header class="b-line-panel-header">
    <button
      class="b-line-panel-back"
      type="button"
      aria-label="Close panel and return to article"
      data-panel-close
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Back to article
    </button>
    <div class="b-line-panel-title-bar">
      <span class="b-line-panel-title">{title}</span>
    </div>
  </header>

  <div class="b-line-panel-body">
    <slot />
  </div>
</div>

<style>
  .b-line-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: min(56rem, 92vw);
    height: 100dvh;
    background: url('https://assets.andrewheins.ca/images/graph-paper.png') left top / cover no-repeat;
    z-index: 50;
    /* transform-origin: top right so the panel swings around its bound edge.
       translateX(130%) ensures the bottom-left corner stays off-screen even
       when rotated 8deg — calculated as cos(8°) + H/W·sin(8°) ≈ 1.16–1.24,
       so 1.30 gives comfortable headroom across all aspect ratios. */
    transform-origin: top right;
    transform: translateX(130%) rotate(8deg);
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .b-line-panel:not([hidden]) {
    display: flex !important;
  }

  .b-line-panel.is-open {
    transform: translateX(0) rotate(0deg);
  }

  /* === Header — always visible === */
  .b-line-panel-header {
    flex-shrink: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .b-line-panel-back {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    width: 100%;
    padding: 0.875rem 2rem 0.875rem 9.375rem; /* 150px left */
    font-size: 0.8125rem;
    font-weight: 500;
    color: #4b5563;
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s;
  }

  .b-line-panel-back:hover {
    color: #111827;
  }

  .b-line-panel-title-bar {
    padding: 0.625rem 2rem 0.875rem 9.375rem; /* 150px left */
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .b-line-panel-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #374151;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* === Body — scrollable === */
  .b-line-panel-body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    /* 100px top, 150px left — clears the torn binding edge */
    padding: 6.25rem 2rem 2rem 9.375rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #374151;
  }

  .b-line-panel-body :global(img),
  .b-line-panel-body :global(svg) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
  }

  .b-line-panel-body :global(p) {
    margin-bottom: 1rem;
  }

  .b-line-panel-body :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
