---
import { Image } from 'astro:assets';

interface Post {
  title: string;
  date: Date;
  annotation: string;
  type: 'essay' | 'curated';
  url: string;
}

interface Props {
  posts: Post[];
  decorLeft?: string;
  decorRight?: string;
  blurb?: string;
}

const { posts, decorLeft, decorRight, blurb } = Astro.props;

const featured = posts[0];
const rest = posts.slice(1);

const formatDate = (d: Date) => d.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="lw-outer">
  {decorLeft && (
    <Image src={decorLeft} alt="" aria-hidden="true" class="lw-decor lw-decor-left" loading="lazy" inferSize format="webp" quality={80} />
  )}
  {decorRight && (
    <Image src={decorRight} alt="" aria-hidden="true" class="lw-decor lw-decor-right" loading="lazy" inferSize format="webp" quality={80} />
  )}

  <section class="lw-section">
    <div class="lw-grid">

      <!-- First in DOM: heading + rest of posts + view all -->
      <div class="lw-right">
        <h2 class="lw-heading">Latest Writing</h2>
        {blurb && <p class="lw-blurb">{blurb}</p>}

        {rest.length > 0 && (
          <div class="lw-rest">
            {rest.map((post) => {
              const isExternal = post.type === 'curated';
              return (
                <article class="lw-rest-item">
                  <h3 class="lw-rest-title">
                    <a
                      href={post.url}
                      {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                    >
                      {post.title}{isExternal && <span aria-label="external link"> ↗</span>}
                    </a>
                  </h3>
                  <time datetime={post.date.toISOString()} class="lw-rest-date">
                    {formatDate(post.date)}
                  </time>
                </article>
              );
            })}
          </div>
        )}

        <a href="/writing/" class="lw-view-all">View all writing →</a>
      </div>

      <!-- Second in DOM, visually first on desktop via order -->
      {featured && (() => {
        const isExternal = featured.type === 'curated';
        return (
          <div class="lw-card-wrap">
            <div class="lw-card">
              <div class="lw-card-meta">
                <span class="lw-card-type">{featured.type === 'curated' ? 'Curated' : 'Essay'}</span>
                <time datetime={featured.date.toISOString()} class="lw-card-date">{formatDate(featured.date)}</time>
              </div>
              <h3 class="lw-card-title">
                <a href={featured.url} {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
                  {featured.title}
                </a>
              </h3>
              <p class="lw-card-annotation">{featured.annotation}</p>
              <a href={featured.url} class="lw-card-link" {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>
                {isExternal ? 'Read ↗' : 'Read →'}
              </a>
              <div class="lw-hole" aria-hidden="true"></div>
            </div>
          </div>
        );
      })()}

    </div>
  </section>
</div>

<style>
  .lw-outer {
    position: relative;
    overflow-x: clip;
  }

  .lw-section {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .lw-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* === Featured card — second in DOM, first visually on desktop === */
  .lw-card-wrap {
    order: -1;
    transform: rotate(-1deg);
  }

  .lw-card {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    padding: 1rem 1.375rem 2.5rem;
    background-color: #f5f3e8;
    box-shadow:
      0 4px 14px rgba(0, 0, 0, 0.18),
      0 1px 3px rgba(0, 0, 0, 0.10);
  }

  @media (max-width: 480px) {
    .lw-card {
      aspect-ratio: unset;
      overflow: visible;
    }
  }

  .lw-hole {
    position: absolute;
    bottom: 0.9rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    border: 1px solid rgba(100, 85, 60, 0.25);
    background: #f8f5f0;
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.35);
  }

  .lw-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .lw-card-type {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b3fa0;
    background: rgba(107, 63, 160, 0.1);
    padding: 0.15rem 0.45rem;
    border-radius: 2px;
  }

  .lw-card-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: #6b5e45;
  }

  .lw-card-title {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    font-weight: bold;
    color: #1c180e;
    line-height: 1.35;
    margin: 0 0 0.75rem;
  }

  .lw-card-title a {
    color: inherit;
    text-decoration: none;
  }

  .lw-card-title a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .lw-card-annotation {
    font-family: 'DM Mono', monospace;
    font-size: 0.775rem;
    line-height: 1.65;
    color: #2a1f0e;
    margin: 0 0 1.25rem;
  }

  .lw-card-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: #6b3fa0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* === Right column === */
  .lw-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .lw-heading {
    font-family: 'Rock Salt', cursive;
    font-size: 1.4rem;
    color: #1c180e;
    line-height: 1.2;
    margin: 0;
  }

  .lw-blurb {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #4a4035;
    margin: 0;
  }

  .lw-rest {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lw-rest-item {
    padding-top: 0.25rem;
  }

  .lw-rest-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  .lw-rest-title a {
    color: #1c180e;
    text-decoration: none;
  }

  .lw-rest-title a:hover {
    color: #6b3fa0;
  }

  .lw-rest-date {
    font-size: 0.7rem;
    color: #9a8a70;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lw-view-all {
    font-size: 0.875rem;
    font-weight: 500;
    color: #1c180e;
    text-decoration: none;
  }

  .lw-view-all:hover {
    color: #6b3fa0;
  }

  /* === Decor === */
  .lw-decor {
    position: absolute;
    display: block;
    height: auto;
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.35));
  }

  .lw-decor-left {
    width: 30rem;
    top: calc(-1rem - 100px);
    left: calc(50% - 24rem - 30rem - 2rem);
    transform: rotate(-12deg);
  }

  .lw-decor-right {
    width: 10rem;
    bottom: calc(1rem - 50px);
    left: calc(50% + 24rem + 2rem - 100px);
    transform: rotate(8deg);
  }

  /* === Mobile === */
  @media (max-width: 640px) {
    .lw-grid {
      grid-template-columns: 1fr;
    }

    /* Reset order so card appears after the text block in single-column flow */
    .lw-card-wrap {
      order: 0;
    }

    .lw-decor {
      display: none;
    }
  }
</style>
