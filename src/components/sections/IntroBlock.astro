---
interface Props {
  body: string;
  decorLeft?: string;
  decorRight?: string;
}

const { body, decorLeft, decorRight } = Astro.props;
---

<div class="intro-outer">
  {decorLeft && (
    <img src={decorLeft} alt="" aria-hidden="true" class="intro-decor intro-decor-left" />
  )}
  {decorRight && (
    <img src={decorRight} alt="" aria-hidden="true" class="intro-decor intro-decor-right" />
  )}
  <section class="max-w-3xl mx-auto px-6 py-16">
    <p class="text-gray-700 text-lg leading-relaxed">{body}</p>
  </section>
</div>

<style>
  .intro-outer {
    position: relative;
    overflow-x: clip;
  }

  .intro-decor {
    position: absolute;
    display: block;
    height: auto;
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.35));
  }

  .intro-decor-left {
    width: 30rem;
    top: calc(-1rem - 100px);
    /* right edge of disc = left + 30rem; anchoring it to section-left (50% - 24rem)
       means left = 50% - 24rem - 30rem. Extra -2rem adds a small gap. */
    left: calc(50% - 24rem - 30rem - 2rem);
    transform: rotate(-12deg);
  }

  .intro-decor-right {
    width: 10rem;
    bottom: calc(1rem - 50px);
    left: calc(50% + 24rem + 2rem - 100px);
    transform: rotate(8deg);
  }

  @media (max-width: 640px) {
    .intro-decor {
      display: none;
    }
  }
</style>
