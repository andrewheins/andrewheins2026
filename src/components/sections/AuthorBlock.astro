---
interface Props {
  name: string;
  headshotUrl: string;
  headline: string;
  employerName: string;
  employerUrl: string;
}

const { name, headshotUrl, headline, employerName, employerUrl } = Astro.props;
---

<aside class="border-t border-gray-100 mt-16 pt-10 pb-16">
  <div class="flex items-center gap-4">
    <a href="/">
      <img
        src={headshotUrl}
        alt={name}
        class="w-14 h-14 rounded-full object-cover"
      />
    </a>
    <div>
      <a href="/" class="font-semibold text-gray-900 hover:text-gray-600 transition-colors">
        {name}
      </a>
      <p class="text-sm text-gray-500">
        {headline} —{' '}
        <a
          href={employerUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:underline"
        >
          {employerName}
        </a>
      </p>
    </div>
  </div>
</aside>
