---
interface Props {
  name: string;
  headshotUrl: string;
  bio: string;
  employerName: string;
  employerUrl: string;
}

const { name, headshotUrl, bio, employerName, employerUrl } = Astro.props;

// Split bio on the employer name so we can wrap it in an anchor
const [before, after] = bio.split(employerName);
---

<aside class="border-t border-gray-100 mt-16 pt-10 pb-16">
  <div class="flex items-start gap-4">
    <a href="/" class="flex-shrink-0 mt-1">
      <img
        src={headshotUrl}
        alt={name}
        class="w-14 h-14 rounded-full object-cover"
      />
    </a>
    <div>
      <a href="/" class="font-semibold text-gray-900 hover:text-gray-600 transition-colors">
        {name}
      </a>
      <p class="text-sm text-gray-600 leading-relaxed mt-1">
        {before}<a
          href={employerUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 hover:text-gray-900 transition-colors"
        >{employerName}</a>{after}
      </p>
    </div>
  </div>
</aside>
