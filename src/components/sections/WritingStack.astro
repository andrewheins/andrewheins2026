---
import { Image } from 'astro:assets';

interface Post {
  title: string;
  date: Date;
  annotation: string;
  type: 'essay' | 'curated';
  url: string;
}

interface Props {
  posts: Post[];
  heading?: string;
  decorRight?: string;
  decorLeft?: string;
}

const { posts, heading = 'Writing', decorRight, decorLeft } = Astro.props;

const rotations = [-1.1, 0.7, -0.4, 1.0, -0.8, 0.5, -1.2, 0.6, -0.3, 0.9];
---

<section class="ws-section">
  {decorLeft && (
    <Image src={decorLeft} alt="" aria-hidden="true" class="ws-decor-left" loading="lazy" width={288} height={288} format="webp" quality={80} />
  )}
  {decorRight && (
    <Image src={decorRight} alt="" aria-hidden="true" class="ws-decor-right" loading="lazy" width={900} height={900} format="webp" quality={75} />
  )}
  {heading && <h2 class="ws-heading">{heading}</h2>}
  <div class="ws-stack">
    {posts.map((post, i) => {
      const tilt = rotations[i % rotations.length];
      const isExternal = post.type === 'curated';
      const isLast = i === posts.length - 1;
      const formattedDate = post.date.toLocaleDateString('en-CA', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
      return (
        <div
          class:list={['ws-card', isLast && 'ws-card--last', posts.length === 1 && 'ws-card--solo']}
          style={`--tilt: ${tilt}deg; z-index: ${i + 1};`}
        >
          <div class="ws-card-inner">
            <div class="ws-meta">
              <span class="ws-type">{post.type === 'curated' ? 'Curated' : 'Essay'}</span>
              <time datetime={post.date.toISOString()} class="ws-date">{formattedDate}</time>
            </div>
            <h3 class="ws-title">
              <a href={post.url} {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}>{post.title}</a>
            </h3>
            <p class="ws-annotation">{post.annotation}</p>
            <a
              href={post.url}
              class="ws-link"
              {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
            >
              {isExternal ? 'Read ↗' : 'Read →'}
            </a>
            <div class="ws-hole" aria-hidden="true"></div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .ws-section {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .ws-heading {
    font-family: 'Rock Salt', cursive;
    font-size: 1.5rem;
    color: #1c180e;
    margin-bottom: 3.5rem;
  }

  .ws-section {
    position: relative;
  }

  .ws-decor-right {
    position: absolute;
    width: 30rem;
    height: auto;
    top: 3.5rem;
    right: -4rem;
    transform: rotate(12deg);
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.35));
    pointer-events: none;
    z-index: 0;
  }

  .ws-decor-left {
    position: absolute;
    width: 8rem;
    height: auto;
    top: 3rem;
    left: -11rem;
    transform: rotate(-8deg);
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.35));
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 640px) {
    .ws-decor-right,
    .ws-decor-left {
      display: none;
    }
  }

  .ws-stack {
    position: relative;
    /* clip the wide invisible hit areas so they don't cause scroll */
    overflow-x: clip;
  }

  /*
   * Outer wrapper: stationary hit area covering both the resting position
   * and the full slide distance. The mouse never leaves this element during
   * the animation, so there's no bounce.
   */
  .ws-card {
    position: relative;
    width: 26rem;
    margin-bottom: -11rem;
    transform: rotate(var(--tilt));
    transition: transform 0.2s ease;
    cursor: default;
  }

  .ws-card--last {
    margin-bottom: 0;
  }

  .ws-card:not(.ws-card--solo):hover,
  .ws-card:not(.ws-card--solo):focus-within {
    transform: rotate(var(--tilt)) translateY(calc(-1 * var(--lift, 2.4rem)));
    transition: transform 0.2s ease;
    z-index: 50;
  }

  .ws-card:not(.ws-card--solo):hover .ws-card-inner,
  .ws-card:not(.ws-card--solo):focus-within .ws-card-inner {
    overflow: visible;
  }

  @media (max-width: 640px) {
    .ws-card:hover,
    .ws-card:focus-within {
      transform: rotate(var(--tilt));
    }
  }

  /* Inner box: visual appearance + content clipping — this is what animates */
  .ws-card-inner {
    position: relative;
    width: 26rem;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    padding: 1rem 1.375rem 2.5rem;
    background-color: #f5f3e8;
    box-shadow:
      0 4px 14px rgba(0, 0, 0, 0.18),
      0 1px 3px rgba(0, 0, 0, 0.10);
  }

  /* Rod hole — matches pillar card style */
  .ws-hole {
    position: absolute;
    bottom: 0.9rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    border: 1px solid rgba(100, 85, 60, 0.25);
    background: #f8f5f0;
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.35);
  }

  /* === Card content === */

  .ws-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .ws-type {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b3fa0;
    background: rgba(107, 63, 160, 0.1);
    padding: 0.15rem 0.45rem;
    border-radius: 2px;
  }

  .ws-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: #6b5e45;
  }

  .ws-title {
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    font-weight: bold;
    color: #1c180e;
    line-height: 1.35;
    margin: 0 0 0.75rem;
  }

  .ws-annotation {
    font-family: 'DM Mono', monospace;
    font-size: 0.775rem;
    line-height: 1.65;
    color: #2a1f0e;
    margin: 0 0 1.25rem;
  }

  .ws-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: #6b3fa0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Mobile: spread cards, full-width with aspect ratio preserved */
  @media (max-width: 640px) {
    .ws-stack {
      overflow-x: visible;
      padding-right: 0.25rem; /* room for the card shadow */
    }

    .ws-card {
      width: 100%;
      margin-bottom: -2.5rem;
    }

    .ws-card-inner {
      width: 100%;
    }
  }

  /* Very small screens: drop aspect ratio so content isn't clipped */
  @media (max-width: 420px) {
    .ws-card-inner {
      aspect-ratio: unset;
    }
  }
</style>

<script>
  function measureLift() {
    const basePx = parseFloat(getComputedStyle(document.documentElement).fontSize);
    const overlapPx = 11 * basePx; // matches margin-bottom: -11rem

    document.querySelectorAll('.ws-card:not(.ws-card--solo)').forEach(card => {
      const inner = card.querySelector('.ws-card-inner');
      if (!inner) return;

      const restingH = inner.offsetHeight;

      // Temporarily remove constraints to measure natural content height
      const prev = { aspectRatio: inner.style.aspectRatio, height: inner.style.height, overflow: inner.style.overflow };
      inner.style.aspectRatio = 'unset';
      inner.style.height = 'auto';
      inner.style.overflow = 'visible';
      const naturalH = inner.scrollHeight;
      inner.style.aspectRatio = prev.aspectRatio;
      inner.style.height = prev.height;
      inner.style.overflow = prev.overflow;

      // Lift enough to bring all content above the next stacked card
      const visibleAtRest = restingH - overlapPx;
      const lift = Math.max(0, naturalH - visibleAtRest);
      card.style.setProperty('--lift', lift + 'px');
    });
  }

  measureLift();

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(measureLift, 150);
  });
</script>
