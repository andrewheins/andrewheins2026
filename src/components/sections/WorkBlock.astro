---
import { Image, getImage } from 'astro:assets';

interface Props {
  body: string;
  ctaPrefix: string;
  ctaLinkText: string;
  ctaUrl: string;
  stickerUrl?: string;
  splotchUrl?: string;
}

const { body, ctaPrefix, ctaLinkText, ctaUrl, stickerUrl, splotchUrl } = Astro.props;

const optimizedSplotch = splotchUrl ? await getImage({
  src: splotchUrl,
  format: 'webp',
  quality: 75,
  width: 900,
  height: 412,
}) : null;
---

<div class="workblock-outer">
  {splotchUrl && (
    <img src={optimizedSplotch!.src} alt="" aria-hidden="true" class="workblock-splotch" loading="lazy" />
  )}
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="workblock-inner">
      {stickerUrl && (
        <div class="workblock-sticker-wrap" aria-hidden="true">
          <Image src={stickerUrl} alt="" class="workblock-sticker" width={252} height={252} format="webp" quality={80} loading="lazy" />
        </div>
      )}
      <div class="workblock-content">
        <p class="text-gray-700 leading-relaxed mb-5">{body}</p>
        <p class="text-gray-700 leading-relaxed">
          {ctaPrefix}<a
            href={ctaUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-900 font-medium underline underline-offset-2 hover:text-gray-600"
          >{ctaLinkText}</a>.
        </p>
      </div>
    </div>
  </section>
</div>

<style>
  .workblock-outer {
    position: relative;
    overflow-x: clip;
  }

  .workblock-splotch {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    pointer-events: none;
    opacity: 0.6;
    z-index: 0;
  }

  .workblock-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .workblock-sticker-wrap {
    flex-shrink: 0;
    width: 7rem;
  }

  .workblock-sticker {
    width: 100%;
    height: auto;
    display: block;
    transform: rotate(-4deg);
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.35));
  }

  .workblock-content {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 640px) {
    .workblock-sticker-wrap {
      position: absolute;
      top: calc(-1rem - 5.6rem);
      left: calc(-1rem - 3.5rem);
      width: 7rem;
      z-index: 0;
      opacity: 0.5;
    }
  }
</style>
