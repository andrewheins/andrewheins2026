---
interface Props {
  heading: string;
  intro: string;
  email: string;
  linkedInUrl: string;
}

const { heading, intro, email, linkedInUrl } = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-16">
  <h2 class="text-3xl font-bold mb-6">{heading}</h2>
  <p class="text-gray-600 leading-relaxed mb-6">{intro}</p>
  <div class="flex gap-6 mb-8 text-sm">
    <a href={`mailto:${email}`} class="text-gray-700 hover:underline">{email}</a>
    <a
      href={linkedInUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-gray-700 hover:underline"
    >
      LinkedIn
    </a>
  </div>
  <slot />
</section>
