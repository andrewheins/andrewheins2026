---
interface Pillar {
  title: string;
  body: string;
}

interface Props {
  intro: string;
  pillars: Pillar[];
}

const { intro, pillars } = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-16 border-t border-gray-100">
  <p class="text-gray-500 leading-relaxed mb-10">{intro}</p>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {pillars.map((pillar) => (
      <div>
        <h3 class="font-semibold text-gray-900 mb-3">{pillar.title}</h3>
        <p class="text-gray-500 text-sm leading-relaxed">{pillar.body}</p>
      </div>
    ))}
  </div>
</section>
