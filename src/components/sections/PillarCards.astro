---
interface Pillar {
  title: string;
  body: string;
}

interface Props {
  title?: string;
  intro?: string;
  pillars: Pillar[];
}

const { title, intro, pillars } = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-16">
  {title && <h2 class="text-3xl font-bold mb-6">{title}</h2>}
  {intro && <p class="text-gray-600 leading-relaxed mb-8">{intro}</p>}
  <div class="pillar-grid">
    {pillars.map((pillar) => (
      <div class="pillar-card">
        <h3 class="pillar-title">{pillar.title}</h3>
        <div class="staple" aria-hidden="true"></div>
        <p class="pillar-body">{pillar.body}</p>
      </div>
    ))}
  </div>
</section>

<style>
  /* === Grid — all breakpoints managed here === */
  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Stagger: two columns, each card cascades down */
  @media (min-width: 640px) and (max-width: 1279px) {
    .pillar-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .pillar-card:nth-child(2) { margin-top: 3.5rem; }
    .pillar-card:nth-child(3) { margin-top: 1.75rem; }
  }

  /* Wide: three equal columns, outset beyond the content column */
  @media (min-width: 1280px) {
    .pillar-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
      margin-left: -200px;
      margin-right: -200px;
    }
  }

  /* === Library index card === */
  .pillar-card {
    position: relative;
    padding: 1rem 1rem 2.5rem 1.375rem;
    background-color: #f5f3e8;
    box-shadow:
      0 4px 14px rgba(0, 0, 0, 0.18),
      0 1px 3px rgba(0, 0, 0, 0.10);
  }

  /* Rod hole at bottom center */
  .pillar-card::after {
    content: '';
    position: absolute;
    bottom: 0.9rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    border: 1px solid rgba(100, 85, 60, 0.25);
    background: #f8f5f0;
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.35);
  }

  /* Slight individual tilts */
  .pillar-card:nth-child(1) { transform: rotate(-1.1deg); }
  .pillar-card:nth-child(2) { transform: rotate( 0.6deg); }
  .pillar-card:nth-child(3) { transform: rotate(-0.4deg); }

  /* === Title — in normal flow, centered on card === */
  .pillar-title {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    font-weight: bold;
    color: #1c180e;
    text-align: center;
    letter-spacing: 0.04em;
    margin: 0 0 0.5rem;
  }

  /* === Staple — block element sitting between title and body === */
  .staple {
    display: block;
    width: 2.625rem;
    height: 3px;
    margin: 0 auto 0.875rem;
    background: linear-gradient(
      to bottom,
      #d4d4d4,
      #9a9a9a 50%,
      #c0c0c0
    );
    border-radius: 1px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  /* === Body text === */
  .pillar-body {
    font-family: 'DM Mono', monospace;
    font-size: 0.775rem;
    line-height: 1.65;
    color: #2a1f0e;
    margin: 0;
  }
</style>
