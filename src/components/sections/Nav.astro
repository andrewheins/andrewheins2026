---
import { siteConfig } from '../../site.config';

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" aria-label="Site navigation">
  <a href="/" class="site-nav-name">
    {siteConfig.authorFullName}
  </a>
  <ul class="site-nav-links" role="list">
    <li>
      <a
        href="/writing"
        class:list={['site-nav-link', { 'is-current': currentPath.startsWith('/writing') }]}
        aria-current={currentPath.startsWith('/writing') ? 'page' : undefined}
      >
        Writing
      </a>
    </li>
  </ul>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 3.5rem;
    background-color: #f8f5f0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .site-nav-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .site-nav-name:hover {
    color: #4b5563;
  }

  .site-nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav-link {
    font-size: 0.875rem;
    color: #4b5563;
    text-decoration: none;
    transition: color 0.15s;
  }

  .site-nav-link:hover,
  .site-nav-link.is-current {
    color: #111827;
  }
</style>
