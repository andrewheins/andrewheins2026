---
import { siteConfig } from '../../site.config';

interface Props {
  theme?: 'light' | 'dark'; // light = dark text (default), dark = white text (over video/dark bg)
}

const { theme = 'light' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!-- Hidden SVG filter — frays the tape edges via turbulence displacement -->
<svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden">
  <defs>
    <filter id="tape-fray" x="-4%" y="-10%" width="108%" height="120%">
      <feTurbulence type="fractalNoise" baseFrequency="0.065 0.12" numOctaves="3" seed="4" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="4" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>
</svg>

<nav class:list={['site-nav', `site-nav--${theme}`]} aria-label="Site navigation">
  <a href="/" class="site-nav-name">
    {siteConfig.authorFullName}
  </a>
  <ul class="site-nav-links" role="list">
    <li>
      <a
        href="/writing"
        class:list={['site-nav-link', { 'is-current': currentPath === '/writing' || currentPath === '/writing/' }]}
        aria-current={currentPath === '/writing' || currentPath === '/writing/' ? 'page' : undefined}
      >
        Writing
      </a>
    </li>
  </ul>
</nav>

<style>
  .site-nav {
    position: relative;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 3.5rem;
  }

  /* === Tape treatment — shared by name and links === */
  /* The tape background lives on ::before so the fray filter applies only
     to the tape surface. Text on the element itself is never displaced. */
  .site-nav-name,
  .site-nav-link {
    display: inline-block;
    position: relative;
    padding: 0.35rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    color: #2a1f0e;
    letter-spacing: 0.01em;
    transition: opacity 0.15s;
  }

  .site-nav-name::before,
  .site-nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;

    /* Tape surface — white, frosted */
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.75) 0%,
      rgba(255, 255, 255, 0.92) 25%,
      rgba(255, 255, 255, 0.92) 75%,
      rgba(255, 255, 255, 0.75) 100%
    );

    /* Tape cut edges */
    border-left:  1px solid rgba(200, 200, 200, 0.6);
    border-right: 1px solid rgba(200, 200, 200, 0.6);

    box-shadow:
      0 2px 5px rgba(0, 0, 0, 0.12),
      0 1px 2px rgba(0, 0, 0, 0.08);

    /* Fray applied only to the background layer */
    filter: url(#tape-fray);
  }

  /* Each piece sits at a slightly different angle */
  .site-nav-name {
    transform: rotate(-1.8deg);
  }

  .site-nav-link {
    transform: rotate(1.2deg);
    font-weight: 500;
  }

  .site-nav-name:hover,
  .site-nav-link:not(.is-current):hover {
    opacity: 0.8;
  }

  .site-nav-link.is-current {
    cursor: default;
    pointer-events: none;
  }

  .site-nav-link.is-current::before {
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(255, 255, 255, 0.97) 25%,
      rgba(255, 255, 255, 0.97) 75%,
      rgba(255, 255, 255, 0.85) 100%
    );
  }

  .site-nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
