---
import { siteConfig } from '../../site.config';

interface Props {
  theme?: 'light' | 'dark'; // light = dark text (default), dark = white text (over video/dark bg)
}

const { theme = 'light' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav class:list={['site-nav', `site-nav--${theme}`]} aria-label="Site navigation">
  <a href="/" class="site-nav-name">
    {siteConfig.authorFullName}
  </a>
  <ul class="site-nav-links" role="list">
    <li>
      <a
        href="/writing"
        class:list={['site-nav-link', { 'is-current': currentPath.startsWith('/writing') }]}
        aria-current={currentPath.startsWith('/writing') ? 'page' : undefined}
      >
        Writing
      </a>
    </li>
  </ul>
</nav>

<style>
  .site-nav {
    position: relative;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 3.5rem;
  }

  /* === Light theme (default) — dark text on light background === */
  .site-nav--light .site-nav-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .site-nav--light .site-nav-name:hover {
    color: #4b5563;
  }

  .site-nav--light .site-nav-link {
    font-size: 0.875rem;
    color: #4b5563;
    text-decoration: none;
    transition: color 0.15s;
  }

  .site-nav--light .site-nav-link:hover,
  .site-nav--light .site-nav-link.is-current {
    color: #111827;
  }

  /* === Dark theme — white text over dark video / dark background === */
  .site-nav--dark .site-nav-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 0.15s;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  .site-nav--dark .site-nav-name:hover {
    color: rgba(255, 255, 255, 0.75);
  }

  .site-nav--dark .site-nav-link {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.15s;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  .site-nav--dark .site-nav-link:hover,
  .site-nav--dark .site-nav-link.is-current {
    color: white;
  }

  .site-nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
