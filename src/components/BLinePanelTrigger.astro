---
interface Props {
  panelId: string;
  label: string;
}

const { panelId, label } = Astro.props;
---

<button
  class="b-line-panel-trigger not-prose inline-flex items-center gap-1.5 text-sm text-gray-600 border border-gray-300 rounded px-3 py-1.5 my-4 hover:border-gray-500 hover:text-gray-900 transition-colors cursor-pointer"
  data-panel-id={panelId}
  type="button"
  aria-haspopup="dialog"
>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="2"/>
    <line x1="9" y1="3" x2="9" y2="21"/>
  </svg>
  {label}
</button>

<script>
  document.querySelectorAll<HTMLButtonElement>('.b-line-panel-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.panelId;
      document.dispatchEvent(new CustomEvent('bline:open-panel', { detail: { panelId: id } }));
    });
  });
</script>
